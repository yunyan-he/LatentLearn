# =====================================================
# LatentLearn Agent Backend — 环境变量配置
# 复制此文件为 agent/.env.agent 并填写真实值
# =====================================================

# ── LLM 接入配置（通用，支持任意 OpenAI-compatible 接口）──────────────────

# LLM 服务商的 API Key
# 当前：OpenRouter (sk-or-v1-...)
# 未来：远程 GPU 实例 / SiliconFlow / DashScope / 自托管 vLLM 均填此处
AGENT_LLM_API_KEY=

# LLM 服务的 Base URL
# OpenRouter:        https://openrouter.ai/api/v1
# 远程 Qwen GPU:     http://<your-server-ip>:8000/v1
# 本地 Ollama:       http://localhost:11434/v1
# DashScope Qwen:    https://dashscope.aliyuncs.com/compatible-mode/v1
AGENT_LLM_BASE_URL=https://openrouter.ai/api/v1

# 使用的模型名称
# ✅ 初期统一使用：google/gemma-4-31b-it:free (或本地 Ollama 的 gemma4:31b)
# 远程 GPU / vLLM 示例：Qwen/Qwen2.5-14B-Instruct, deepseek-ai/DeepSeek-R1-Distill-Qwen-14B
AGENT_LLM_MODEL=google/gemma-4-31b-it:free

# ── 可选：OpenRouter 专属 attribution headers ─────────────────────────────
# 不使用 OpenRouter 时留空即可
AGENT_LLM_HTTP_REFERER=http://localhost:3000
AGENT_LLM_APP_TITLE=LatentLearn

# ── 生成参数 ───────────────────────────────────────────────────────────────
AGENT_LLM_TEMPERATURE=0.4
AGENT_LLM_MAX_TOKENS=2000

# ── FastAPI 服务配置 ───────────────────────────────────────────────────────
AGENT_HOST=127.0.0.1
AGENT_PORT=8100

# ── CORS 白名单（前端地址）────────────────────────────────────────────────
AGENT_CORS_ORIGINS=http://localhost:3000

# ── LangSmith 可观测性（可选，留空则不上报）──────────────────────────────
# ✅ 已确认加入：便于比赛演示 trace/graph 可视化
# 1. 前往 https://smith.langchain.com 注册账号
# 2. 创建 API Key（Settings → API Keys）
# 3. 填入下方，启动后端即可在 LangSmith 看到每次调用的完整 trace
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=latentlearn-agent
# true = 上报 trace；false = 不上报（生产环境或离线时关闭）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

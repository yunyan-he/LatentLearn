# LLM provider configuration.
# This project calls an OpenAI-compatible Chat Completions endpoint:
#   POST {LLM_BASE_URL}{LLM_CHAT_COMPLETIONS_PATH}

# DeepSeek official API.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_MODEL=deepseek-v4-flash
LLM_REQUIRE_FREE_MODEL=false

# Generation settings.
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2200

# ── LangGraph Agent 后端地址 ────────────────────────────────────────────────
# 设置后，Next.js API 路由将自动代理至 LangGraph Python 后端。
# 留空或删除此行 = 使用原有直连 LLM 逻辑（fallback 模式）。
AGENT_API_URL=http://127.0.0.1:8100

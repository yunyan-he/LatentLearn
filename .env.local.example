# LLM provider configuration.
# This project calls an OpenAI-compatible Chat Completions endpoint:
#   POST {LLM_BASE_URL}{LLM_CHAT_COMPLETIONS_PATH}
#
# Supported examples:
# 1. OpenRouter:
#    LLM_PROVIDER=openrouter
#    LLM_BASE_URL=https://openrouter.ai
#    LLM_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
#    LLM_MODEL=google/gemma-4-31b-it:free
#    Optional headers:
#      LLM_HTTP_REFERER=http://localhost:3000
#      LLM_APP_TITLE=LatentLearn
#
# 2. DeepSeek official API:
#    LLM_PROVIDER=deepseek
#    LLM_BASE_URL=https://api.deepseek.com
#    LLM_CHAT_COMPLETIONS_PATH=/chat/completions
#    LLM_MODEL=deepseek-chat
#    Set LLM_REQUIRE_FREE_MODEL=false because official DeepSeek models do not use OpenRouter's ":free" suffix.
#
# 3. Qwen / Alibaba DashScope OpenAI-compatible API:
#    LLM_PROVIDER=qwen
#    LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#    LLM_CHAT_COMPLETIONS_PATH=/chat/completions
#    LLM_MODEL=qwen-plus
#    Set LLM_REQUIRE_FREE_MODEL=false unless your provider model id explicitly ends with ":free".

# API key for whichever provider you choose. Used as a fallback when tier keys are empty.
# Keep real keys only in .env.local. Do not commit them.
LLM_API_KEY=

# Active provider label. Used for clearer error messages.
LLM_PROVIDER=openrouter

# Endpoint.
LLM_BASE_URL=https://openrouter.ai
LLM_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions

# Default model. Used as a fallback when a tier-specific model is not set.
LLM_MODEL=google/gemma-4-31b-it:free

# Optional workload tiers for the direct Next.js fallback path.
# fast: JSON planning, tree placement, path summaries.
# balanced: normal tutoring and follow-up answers.
# strong: reserved for future deep reasoning flows.
#
# Each tier may use a different OpenAI-compatible provider.
LLM_FAST_PROVIDER=openrouter
LLM_FAST_API_KEY=
LLM_FAST_BASE_URL=https://openrouter.ai
LLM_FAST_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
LLM_FAST_MODEL=tencent/hy3:free
LLM_FAST_REQUIRE_FREE_MODEL=true

LLM_BALANCED_PROVIDER=gemini
LLM_BALANCED_API_KEY=
LLM_BALANCED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_BALANCED_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_BALANCED_MODEL=gemini-3.5-flash
LLM_BALANCED_REQUIRE_FREE_MODEL=false

LLM_STRONG_PROVIDER=deepseek
LLM_STRONG_API_KEY=
LLM_STRONG_BASE_URL=https://api.deepseek.com
LLM_STRONG_CHAT_COMPLETIONS_PATH=/chat/completions
LLM_STRONG_MODEL=deepseek-v4-pro
LLM_STRONG_REQUIRE_FREE_MODEL=false

# true by default: route complex tutor requests to the strong tier.
LLM_AUTO_STRONG=true

# Cost guard.
# true: require fallback LLM_MODEL to end with ":free" (best for OpenRouter free models).
# false: allow official provider model ids such as deepseek-chat or gemini-3.5-flash.
LLM_REQUIRE_FREE_MODEL=false

# Optional attribution headers. OpenRouter uses these; official Qwen/DeepSeek can leave them blank.
LLM_HTTP_REFERER=http://localhost:3000
LLM_APP_TITLE=LatentLearn

# Generation settings.
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1800
LLM_FAST_TEMPERATURE=0.2
LLM_FAST_MAX_TOKENS=1000
LLM_BALANCED_TEMPERATURE=0.4
LLM_BALANCED_MAX_TOKENS=2000
LLM_STRONG_TEMPERATURE=0.5
LLM_STRONG_MAX_TOKENS=3000

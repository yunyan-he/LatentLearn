# LLM provider configuration.
# This project calls an OpenAI-compatible Chat Completions endpoint:
#   POST {LLM_BASE_URL}{LLM_CHAT_COMPLETIONS_PATH}
#
# Supported examples:
# 1. OpenRouter:
#    LLM_PROVIDER=openrouter
#    LLM_BASE_URL=https://openrouter.ai
#    LLM_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions
#    LLM_MODEL=google/gemma-4-31b-it:free
#    Optional headers:
#      LLM_HTTP_REFERER=http://localhost:3000
#      LLM_APP_TITLE=LatentLearn
#
# 2. DeepSeek official API:
#    LLM_PROVIDER=deepseek
#    LLM_BASE_URL=https://api.deepseek.com
#    LLM_CHAT_COMPLETIONS_PATH=/chat/completions
#    LLM_MODEL=deepseek-chat
#    Set LLM_REQUIRE_FREE_MODEL=false because official DeepSeek models do not use OpenRouter's ":free" suffix.
#
# 3. Qwen / Alibaba DashScope OpenAI-compatible API:
#    LLM_PROVIDER=qwen
#    LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#    LLM_CHAT_COMPLETIONS_PATH=/chat/completions
#    LLM_MODEL=qwen-plus
#    Set LLM_REQUIRE_FREE_MODEL=false unless your provider model id explicitly ends with ":free".

# API key for whichever provider you choose.
# Keep the real key only in .env.local. Do not commit it.
LLM_API_KEY=

# Active provider label. Used for clearer error messages.
LLM_PROVIDER=openrouter

# Endpoint.
LLM_BASE_URL=https://openrouter.ai
LLM_CHAT_COMPLETIONS_PATH=/api/v1/chat/completions

# Model.
LLM_MODEL=google/gemma-4-31b-it:free

# Cost guard.
# true: require LLM_MODEL to end with ":free" (best for OpenRouter free models).
# false: allow official provider model ids such as deepseek-chat or qwen-plus.
LLM_REQUIRE_FREE_MODEL=true

# Optional attribution headers. OpenRouter uses these; official Qwen/DeepSeek can leave them blank.
LLM_HTTP_REFERER=http://localhost:3000
LLM_APP_TITLE=LatentLearn

# Generation settings.
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1800
